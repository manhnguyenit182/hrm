# Environment Variables Example
# Copy this file to .env and replace the values with your own securely generated secrets.
# Do NOT commit your actual .env file to version control.

# Prisma Postgres Connection String
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_PRISMA_API_KEY_HERE"

# NextAuth / JWT Secret
# Generate a secure string: openssl rand -base64 32
NEXTAUTH_SECRET="your-secure-nextauth-secret-here"
JWT_SECRET="your-secure-jwt-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary Integration (for file uploads)
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"

# Google OAuth Integration (if applicable)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
